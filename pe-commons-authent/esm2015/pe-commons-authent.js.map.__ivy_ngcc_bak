    "import { PeAuthType, OpenAMOptions } from '../declarations/index';\nimport { HttpClient, HttpParams } from '@angular/common/http';\nimport { PeAuthFlow } from './flows/pe-auth-flow';\nimport { AuthorizationCodeFlow } from './flows/authorization-code.flow';\nimport { ImplicitFlow } from './flows/implicit.flow';\nimport { formatCookieName } from './utils/cookie';\nimport { AuthorizationCodeWithPKCEFlow } from './flows/authorization-code-PKCE.flow';\nimport * as CryptoJS from 'crypto-js';\n\nexport class OpenAMType implements PeAuthType {\n\n    private http: HttpClient;\n    \n    static readonly FLOW_AUTHORIZATION_CODE = \"authorizationCodeFlow\";\n    static readonly FLOW_IMPLICIT = \"implicitFlow\";\n    static readonly FLOW_AUTHORIZATION_CODE_WITH_PKCE = \"authorizationCodeWithPKCEFlow\";\n    \n    ready: Promise<OpenAMType>;\n    \n    cxnUrl: string;\n\n    autoReload = false;\n\n    cookieName = 'userBadge';\n    private static readonly COOKIE_SUFFIXE: any = {\n        agent: 'A',\n        individu: 'I',\n        employeur: 'E',\n        partenaire: 'P'\n    };\n\n    private _options: OpenAMOptions;\n    private _redirect_uri: string;\n    private _state: string;\n    private _nonce: string;\n    private _verifier: string;\n    private _code_challenge: string;\n    private _code_challenge_method: string;\n    \n    private storage = localStorage;\n    private _storageKey: string;\n\n    private _flow: PeAuthFlow;\n\n    constructor(openAMOptions: OpenAMOptions, mode:string, redirect: string, http: HttpClient) {\n      this.cookieName = formatCookieName(this.cookieName, openAMOptions.cadre, OpenAMType.COOKIE_SUFFIXE[mode]);  \n      this._options = openAMOptions;\n      this._redirect_uri = redirect;\n      this._state = this.randomizeString(16);\n      this._nonce = this.randomizeString(16);\n      this.cxnUrl = this.buildCxnUrl(mode);\n      this._storageKey = '__' + openAMOptions.clientId;\n      this.http = http;\n\n      switch (this._options.accessT